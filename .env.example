# =============================================================================
# BEZPIECZEŃSTWO: Klucze API działają WYŁĄCZNIE po stronie serwera (API Routes).
# Celowo NIE używamy prefiksu NEXT_PUBLIC_ — zmienne z tym prefiksem trafiają
# do bundle'a JavaScript przeglądarki i byłyby widoczne dla każdego użytkownika.
# Skopiuj ten plik jako `.env.local` i uzupełnij wartości.
# =============================================================================

# https://www.abuseipdb.com/account/api (darmowy plan: 1000 zapytań/dzień)
ABUSEIPDB_API_KEY=

# https://www.virustotal.com/gui/my-apikey (darmowy plan: 4 zapytania/min, 500/dzień)
VIRUSTOTAL_API_KEY=

# https://app.crowdsec.net -> Settings -> CTI API Keys (darmowy plan z dziennym limitem)
CROWDSEC_CTI_API_KEY=

# IP-API (geolokalizacja) nie wymaga klucza — brak wpisu jest zamierzony.
